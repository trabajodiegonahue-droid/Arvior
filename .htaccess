RewriteEngine On

ErrorDocument 404 /404.php

# Sitemap y robots dinámicos.
RewriteRule ^sitemap\.xml$ /sitemap.xml.php [L]
RewriteRule ^robots\.txt$  /robots.txt.php  [L]

# Forzar HTTPS (Hostinger setea HTTPS=on detrás del proxy).
<IfModule mod_rewrite.c>
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
</IfModule>

<FilesMatch "^(config\.php|config\.example\.php|\.gitignore|\.env|composer\.json|composer\.lock)$">
    Require all denied
</FilesMatch>

RewriteRule ^lib/           - [F,L]
RewriteRule ^migrations/    - [F,L]
RewriteRule ^components/    - [F,L]
RewriteRule ^uploads/logs/  - [F,L]

# Nunca exponer el repositorio ni la documentación interna por web.
RewriteRule ^\.git          - [F,L]
RewriteRule ^docs/          - [F,L]
RewriteRule ^Guias/         - [F,L]
RewriteRule ^DEPLOY\.md$    - [F,L]

# Bloquear cualquier archivo/carpeta oculta (.git, .env, etc.).
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>
